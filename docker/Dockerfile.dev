FROM nvcr.io/nvidia/cuda:12.2.0-devel-ubuntu22.04

# 1. Install base dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# 2. Configure NVIDIA repository
RUN apt-key adv --fetch-keys https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2204/x86_64/3bf863cc.pub && \
    echo "deb https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2204/x86_64 /" | tee /etc/apt/sources.list.d/cuda.list

# 3. Install CUDA components with verified package names
RUN apt-get update && apt-get install -y --no-install-recommends \
    cuda-samples-12-2-0 \
    cuda-nvtx-12-2 \
    cuda-gdb-12-2 \
    && rm -rf /var/lib/apt/lists/*

# 4. Build and install GTest from source
WORKDIR /usr/src/gtest
RUN cmake CMakeLists.txt && make && cp *.a /usr/lib

# 5. Set up CUDA samples
RUN cp -r /usr/local/cuda-12.2/samples /workspace/cuda_samples && \
    cd /workspace/cuda_samples/0_Simple/vectorAdd && make

WORKDIR /workspace