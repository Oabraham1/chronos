# Optimized production image
FROM nvcr.io/nvidia/cuda:12.2.0-runtime-ubuntu22.04

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy built binaries
WORKDIR /app
COPY build/gpu_partitioner .

# Entrypoint
CMD ["./gpu_partitioner"]